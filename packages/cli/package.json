{
  "name": "agentq",
  "version": "0.1.1",
  "description": "The handshake between coding agents.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "coding-agent",
    "agent",
    "cli",
    "coordination",
    "hooks",
    "queue"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yonggyun-superlazy/agentq.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/yonggyun-superlazy/agentq/issues"
  },
  "homepage": "https://github.com/yonggyun-superlazy/agentq#readme",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "bin": {
    "agentq": "./dist/main.js"
  },
  "main": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@agentq/core": "workspace:*"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
